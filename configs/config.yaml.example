telegram:
  bot_token: ""
  admin_user_id: 123456789
  proxy: ""
  timeout_sec: 180

llm:
  timeout_sec: 180

  # 注意：openai_custom 与 openrouter 必须且仅能启用一个
  # OpenAI 兼容
  openai_custom:
    enable: true
    base_url: "https://api.openai.com/v1"
    api_key: ""
    model: "gpt-4o-mini"
    proxy: ""

  # OpenRouter
  openrouter:
    enable: false
    api_key: ""
    model: "gpt-4o-mini"
    proxy: ""

nai:
  base_url: "https://image.idlecloud.cc/api"
  api_key: ""
  model: "nai-diffusion-4-5-full"
  timeout_sec: 180
  proxy: ""
